{
  "name": "narrative-skills-marketplace",
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@types/bun": "latest",
    "gray-matter": "^4.0.3",
    "knip": "^6.14.1",
    "lefthook": "^2.1.8",
    "typescript": "^6.0.0"
  },
  "private": true,
  "scripts": {
    "gen:skill-docs": "bun run scripts/gen-skill-docs.ts",
    "gen:mcp": "bun run scripts/gen-mcp-config.ts",
    "gen:skills-index": "bun run scripts/gen-skills-index.ts",
    "gen:readme": "bun run scripts/gen-readme.ts",
    "gen:all": "bun run gen:skill-docs && bun run gen:mcp && bun run gen:skills-index && bun run gen:readme",
    "build:portable": "bun run gen:all && bun run scripts/build-portable.ts",
    "check:skill-docs": "bun run scripts/gen-skill-docs.ts --dry-run",
    "check:mcp": "bun run scripts/gen-mcp-config.ts --dry-run",
    "check:skills-index": "bun run scripts/gen-skills-index.ts --dry-run",
    "check:readme": "bun run scripts/gen-readme.ts --dry-run",
    "check:manifests": "bun run scripts/check-manifests.ts",
    "check:spec": "bun run scripts/check-spec.ts",
    "check:versions": "bun run scripts/check-skill-versions.ts",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "ci": "bun run check:skill-docs && bun run check:mcp && bun run check:skills-index && bun run check:readme && bun run check:manifests && bun run check:spec && bun run check:versions && bun run check && bun run typecheck && bun run knip",
    "release": "bun run scripts/release.ts",
    "release:apply": "bun run scripts/release.ts --apply",
    "release:tag": "bun run scripts/release.ts --tag",
    "commitlint": "commitlint",
    "hooks:install": "lefthook install"
  },
  "type": "module"
}
