{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits",
    "helpers:pinGitHubActionDigests"
  ],
  "timezone": "America/New_York",
  "schedule": ["before 9am on monday"],
  "labels": ["dependencies"],
  "prHourlyLimit": 4,
  "prConcurrentLimit": 10,
  "rangeStrategy": "bump",
  "minimumReleaseAge": "14 days",
  "internalChecksFilter": "strict",
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 9am on the first day of the month"]
  },
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch"],
      "matchCurrentVersion": "!/^0/",
      "groupName": "minor and patch updates",
      "groupSlug": "minor-patch"
    },
    {
      "matchUpdateTypes": ["minor", "patch"],
      "matchCurrentVersion": "/^0/",
      "groupName": "0.x minor and patch updates",
      "groupSlug": "zero-x-minor-patch",
      "description": "Pre-1.0 packages: a 'minor' bump can be breaking, so keep them separate from stable minors but still grouped."
    },
    {
      "matchManagers": ["github-actions"],
      "groupName": "github actions",
      "groupSlug": "github-actions",
      "pinDigests": true
    },
    {
      "matchPackageNames": ["typescript"],
      "minimumReleaseAge": "30 days"
    },
    {
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["pin", "digest"],
      "automerge": false
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"],
    "minimumReleaseAge": "0 days",
    "schedule": ["at any time"]
  }
}
