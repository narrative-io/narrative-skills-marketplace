#!/usr/bin/env bash
set -euo pipefail

# narrative-skills-marketplace setup.
#
# Default mode (no args): register the marketplace + install plugins via
# the `claude` CLI. Use this on Claude Code.
#
# Portable mode (`bash setup --portable`): render everything but skip
# the `claude` CLI entirely. Produces dist/skills/, dist/mcp/, and
# dist/skills.json, then prints copy-paste instructions for Claude.ai
# Skills, Claude Desktop, Cursor, and other agentskills.io-compliant
# harnesses. Requires Bun; does not require the `claude` CLI.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
MARKETPLACE_JSON="$SCRIPT_DIR/.claude-plugin/marketplace.json"

MODE="claude-code"
for arg in "$@"; do
  case "$arg" in
    --portable) MODE="portable" ;;
    -h|--help)
      cat <<EOF
Usage: bash setup [--portable]

  (no flag)    Install via Claude Code CLI (default).
  --portable   Build dist/ for non-Claude-Code harnesses.
EOF
      exit 0
      ;;
    *)
      echo "error: unknown flag '$arg' (run 'bash setup --help')." >&2
      exit 1
      ;;
  esac
done

echo "=== narrative-skills-marketplace setup ($MODE) ==="
echo ""

if [ ! -f "$MARKETPLACE_JSON" ]; then
  echo "error: $MARKETPLACE_JSON not found." >&2
  exit 1
fi

# ─── Render templates + derived artifacts (both modes) ────────
# Skills using shared snippets (e.g. {{SNIPPET:pin-company-context}}) need
# this step to produce the SKILL.md that the plugin loader actually reads.
# See scripts/gen-skill-docs.ts and AGENTS.md ("Template system") for details.
if command -v bun >/dev/null 2>&1; then
  if [ ! -d "$SCRIPT_DIR/node_modules" ] && [ -f "$SCRIPT_DIR/package.json" ]; then
    echo "Installing template-renderer dependencies..."
    (cd "$SCRIPT_DIR" && bun install --silent)
  fi
  if [ -f "$SCRIPT_DIR/scripts/gen-skill-docs.ts" ]; then
    echo "Rendering SKILL.md from templates + mcp.json + skills.json..."
    (cd "$SCRIPT_DIR" && bun run gen:all)
  fi
  # Install local git hooks (commitlint) for contributors. Silently
  # skip outside a git working tree or when lefthook isn't installed
  # (end users running `bash setup` just to install plugins don't
  # need hooks).
  if [ -d "$SCRIPT_DIR/.git" ] && [ -f "$SCRIPT_DIR/lefthook.yml" ]; then
    if (cd "$SCRIPT_DIR" && bunx --bun lefthook install >/dev/null 2>&1); then
      echo "Installed git hooks (commit-msg → commitlint)."
    fi
  fi
else
  # Bun is required only when there are .tmpl files to render. Without
  # it, fail loudly only if any .tmpl exists; otherwise the install
  # proceeds with whatever SKILL.md files are already committed.
  if find "$SCRIPT_DIR/plugins" -name 'SKILL.md.tmpl' -print -quit | grep -q .; then
    echo "error: 'bun' is not on PATH but SKILL.md.tmpl templates exist." >&2
    echo "       Install Bun (https://bun.sh) or commit pre-rendered SKILL.md files." >&2
    exit 1
  fi
fi

# ─── Portable mode: build dist/ and exit ──────────────────────
if [ "$MODE" = "portable" ]; then
  if ! command -v bun >/dev/null 2>&1; then
    echo "error: --portable requires Bun (https://bun.sh)." >&2
    exit 1
  fi
  (cd "$SCRIPT_DIR" && bun run build:portable)
  echo ""
  echo "=== Portable build complete ==="
  echo "See $SCRIPT_DIR/dist/ for the rendered artifacts and the README"
  echo "for per-harness installation recipes."
  exit 0
fi

# ─── Claude Code mode (default): register + install ───────────
if ! command -v claude >/dev/null 2>&1; then
  echo "error: the 'claude' CLI is not on PATH. Install Claude Code first," >&2
  echo "       or re-run with 'bash setup --portable' to build a harness-" >&2
  echo "       agnostic distribution under dist/." >&2
  exit 1
fi

MARKETPLACE_NAME=$(grep -m1 '"name"' "$MARKETPLACE_JSON" | sed -E 's/.*"name"[[:space:]]*:[[:space:]]*"([^"]+)".*/\1/')

echo "Registering plugin marketplace..."
claude plugin marketplace add "$SCRIPT_DIR"

echo "Installing plugins..."
# Parse the top-level plugins[].name entries from marketplace.json.
if command -v jq >/dev/null 2>&1; then
  PLUGIN_NAMES=$(jq -r '.plugins[].name' "$MARKETPLACE_JSON")
elif command -v python3 >/dev/null 2>&1; then
  PLUGIN_NAMES=$(python3 -c '
import json, sys
with open(sys.argv[1]) as f:
    data = json.load(f)
for p in data.get("plugins", []):
    print(p["name"])
' "$MARKETPLACE_JSON")
else
  echo "error: neither 'jq' nor 'python3' is available to parse marketplace.json." >&2
  exit 1
fi

for name in $PLUGIN_NAMES; do
  echo "  - $name"
  claude plugin install "$name@$MARKETPLACE_NAME"
done

echo ""
echo "Regenerating README plugin catalog..."
if command -v bun >/dev/null 2>&1; then
  bun "$SCRIPT_DIR/scripts/regen-readme.ts" "$SCRIPT_DIR"
else
  echo "  warning: bun not available, skipping README regen." >&2
  echo "  install bun from https://bun.sh and re-run this script." >&2
fi

echo ""
echo "=== Setup complete ==="
echo "Try it: open Claude Code and type / to browse installed skills,"
echo "or run one directly, e.g. /write-nql or /generate-rosetta-stone-mappings."
